TOKENHUB_ENV=prod
TOKENHUB_PUBLIC_BASE_URL=http://localhost:8080
TOKENHUB_ADMIN_TOKEN=change-me-tokenhub-admin-token
TOKENHUB_SECRET_KEY=change-me-tokenhub-secret-key
TOKENHUB_BACKEND_PORT=8080
TOKENHUB_FRONTEND_PORT=3000
TOKENHUB_SEED_DEMO=false
TOKENHUB_LOG_LEVEL=info
TOKENHUB_RESOURCE_FAILURE_THRESHOLD=3
TOKENHUB_RESOURCE_COOLDOWN_SECONDS=300

# PostgreSQL 配置 (用于 docker-compose.postgres.yml)
POSTGRES_DB=tokenhub
POSTGRES_USER=tokenhub
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_PORT=5432

# PostgreSQL 连接池配置
TOKENHUB_DB_MAX_OPEN_CONNS=25
TOKENHUB_DB_MAX_IDLE_CONNS=5
TOKENHUB_DB_CONN_MAX_LIFETIME_MINUTES=30

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME=TokenHub
